{
  "permissions": {
    "allow": [
      "Bash(xargs grep -l \"react\\\\|vue\\\\|angular\\\\|svelte\")",
      "Bash(grep -r 'CREATE TABLE' /home/shubh4m/projects/Meet-Rub --include=*.js --include=*.sql)",
      "Bash(grep -r \"delivery_time\" /home/shubh4m/projects/Meet-Rub/backend --include=\"*.js\" ! -path \"*/node_modules/*\")",
      "mcp__code-review-graph__build_or_update_graph_tool",
      "mcp__code-review-graph__semantic_search_nodes_tool",
      "Read(//temp/readonly/**)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|Bash",
        "command": "code-review-graph update --quiet",
        "timeout": 5000
      }
    ],
    "SessionStart": [
      {
        "command": "code-review-graph status --json",
        "timeout": 3000
      }
    ],
    "PreCommit": [
      {
        "command": "code-review-graph detect-changes --brief",
        "timeout": 10000
      }
    ]
  }
}
